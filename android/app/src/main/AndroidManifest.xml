<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 常時電源接続プロファイルがPARTIAL_WAKE_LOCKでスリープを防ぐために
         必要(open-web-server版と同じ方針、PowerProfile.kt参照)。
         省電力/通常プロファイルでは取得しない。 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- ACTION_POWER_DISCONNECTED/CONNECTEDはprotected broadcastのため、
         マニフェスト側の権限宣言は不要(コード側でreceiverを動的登録)。 -->

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_normal"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RPoem"
        android:usesCleartextTraffic="true">

        <!--
          起動時の電源プロファイル選択画面をLAUNCHERにする
          (open-web-server版と同じパターン、絵文字+日本語ラベルで区別)。
        -->
        <activity
            android:name=".ProfileSelectActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          RPoem(open-runo-router)はTomcat相当の汎用アプリケーション
          サーバー層であり、Android端末上でネイティブバイナリを
          ProcessBuilder起動する設計は採らない(`../CLAUDE.md`HANDOFF
          参照)。`MainActivity`はどこかで稼働中のRPoemインスタンスへの
          「接続設定+死活監視クライアント」として機能する。
        -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!--
          3電源プロファイルそれぞれの専用ホーム画面アイコン
          (open-web-server版と同じ設計: 色分け+ラベル文字列で誤選択防止)。
        -->
        <activity-alias
            android:name=".LauncherPowerSave"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_powersave"
            android:label="@string/app_name_powersave"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.rpoem.LAUNCH_POWER_SAVE" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherNormal"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_normal"
            android:label="@string/app_name_normal"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.rpoem.LAUNCH_NORMAL" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherAlwaysOn"
            android:targetActivity=".MainActivity"
            android:icon="@drawable/ic_launcher_alwayson"
            android:label="@string/app_name_alwayson"
            android:exported="true">
            <intent-filter>
                <action android:name="tokyo.runo.rpoem.LAUNCH_ALWAYS_ON" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
