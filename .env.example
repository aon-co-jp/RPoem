# Copy this file to `.env` for local development.
# `openruno-router` reads these via `openruno_core::Config::from_env`.
# See DEVELOPMENT.md for details.

# local | development | staging | production
OPENRUNO_ENV=local

# Address the Gateway Router binds to.
OPENRUNO_BIND_ADDR=0.0.0.0:8080

# tracing / tracing-subscriber EnvFilter directive, e.g. info, debug,
# openruno_router=debug,info
OPENRUNO_LOG_LEVEL=info

# Only needed when building/running openruno-db with the `postgres` feature.
# See docker-compose.yml for a matching local Postgres instance.
DATABASE_URL=postgres://postgres:openruno@localhost:5432/postgres

# Rate limit applied by openruno-router's rate-limiting middleware
# (see crates/openruno-router/src/rate_limit.rs).
OPENRUNO_RATE_LIMIT_MAX_REQUESTS=120
OPENRUNO_RATE_LIMIT_WINDOW_SECS=60
